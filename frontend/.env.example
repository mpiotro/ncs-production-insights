# NCS Production Insights — frontend configuration (004-R5).
# Copy to `.env.local` (gitignored) and adjust. NO secrets here (principle 7) — these
# are public, non-sensitive values: a base URL and a data-source switch.

# Base URL of the 003 API. Each worktree uses a distinct port (tech-standards: parallel
# worktrees); phase 003 runs on 8003 locally.
VITE_API_BASE_URL=http://localhost:8003

# Which NcsApiClient to use: "mock" (in-memory fixtures, no network) or "http" (live 003).
# Switching mock <-> live is configuration only — no code change (004-R5).
VITE_API_SOURCE=mock
